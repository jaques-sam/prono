#!/bin/sh

BINARY="/var/packages/prono-backend/target/prono-backend"
PID_FILE="/var/packages/prono-backend/target/prono-backend.pid"
LOG_FILE="/var/packages/prono-backend/target/prono-backend.log"
ENV_FILE="/var/packages/prono-backend/etc/env"

case "$1" in
    start)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "Already running"
            exit 0
        fi
        while IFS='=' read -r _key _val; do
            case "$_key" in ''|\#*) continue ;; esac
            [ -n "$_val" ] && export "${_key}=${_val}"
        done < "$ENV_FILE"
        export RUST_LOG="${RUST_LOG:-info}"
        "$BINARY" >> "$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
        ;;
    stop)
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")" 2>/dev/null
            rm -f "$PID_FILE"
        fi
        ;;
    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            exit 0
        fi
        exit 3
        ;;
esac

exit 0
